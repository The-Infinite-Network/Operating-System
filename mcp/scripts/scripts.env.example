# Google Drive Service Account Configuration
# Copy this file to scripts.env and set your actual values

# Service account JSON key file path (Windows or Unix)
# Windows example: C:/keys/ie-mcp-drive.json or C:\\keys\\ie-mcp-drive.json
# Unix example: /path/to/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS=C:/keys/ie-mcp-drive.json

# Shared Drive ID (required)
GOOGLE_SHARED_DRIVE_ID=YOUR_SHARED_DRIVE_ID

# Canon root folder name (optional, defaults to INFINITE_NETWORK_CANON)
CANON_ROOT_NAME=INFINITE_NETWORK_CANON

# Canon root folder ID (optional, skip name lookup if provided)
# CANON_ROOT_ID=1a2b3c4d5e6f7g8h9i0j

# Legacy: Support GOOGLE_SERVICE_ACCOUNT_KEY_PATH (will be mapped to GOOGLE_APPLICATION_CREDENTIALS)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=C:/keys/ie-mcp-drive.json
