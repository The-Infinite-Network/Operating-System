############################################
# IEHQ Notion MCP — Canon Env v2.0
# INOS Epoch 0 — Ten Canonical Databases
############################################

############################################
# Runtime / Server
############################################

PORT=3002
NODE_ENV=development

# Comma-separated origins for CORS
CORS_ALLOWED_ORIGINS=https://inos.theinfinitenetwork.com,http://localhost:5173

############################################
# Notion Auth (REQUIRED)
############################################

NOTION_API_KEY=secret_...
NOTION_VERSION=2022-06-28

############################################
# INOS Epoch 0 — Ten Canonical DB IDs (REQUIRED after Notion rebuild)
# See: INOS Notion Rebuild Spec v1.0, Part 6.1
############################################

NOTION_IDENTITY_DB_ID=           # 🪪 [IN] Identity
NOTION_TIMELINE_DB_ID=           # ⏱️ [IN] Timeline
NOTION_MISSIONS_DB_ID=           # 🎯 [WAR] Missions
NOTION_MISSION_RUNS_DB_ID=       # Active Mission Runs write surface
NOTION_SPECS_DB_ID=              # 📐 [ARK] Specs
NOTION_CANON_REGISTRY_DB_ID=     # 📜 [ARK] Canon Registry
NOTION_POLICIES_DB_ID=           # ⚖️ [LAW] Policies
NOTION_APPROVALS_DB_ID=          # ✅ [LAW] Approvals & Decisions
NOTION_ARTIFACT_INDEX_DB_ID=     # 🧠 [MIND] Artifact Index
NOTION_KNOWLEDGE_ARTICLES_DB_ID= # 📚 [IN] Knowledge Articles

############################################
# Additional Canon Database Surfaces
# Active database surfaces outside the Epoch 0 core set.
############################################

NOTION_FOOD_INGREDIENTS_DB_ID=   # 🍕 [FOOD] Ingredients

############################################
# Legacy DB IDs (pre-rebuild; kept for backward compat)
# If you set the canonical IDs above, you can leave these blank.
############################################

NOTION_DB_MISSIONS=
NOTION_DB_TASKS=                 # Controlled legacy-parent exception; do not widen writer scope
NOTION_DB_RUNS_AARS=             # Compatibility alias to the live Mission Runs surface
NOTION_DB_TIMELINE=
NOTION_DB_INBOX=
NOTION_DB_AGENTS=
NOTION_DB_ENTITIES=
NOTION_DB_ROOMS=
NOTION_DB_ARK_REGISTRY=
NOTION_DB_CLASS_KB=
NOTION_DB_LAW_DOCS=
NOTION_DB_ARK_ASSETS=
NOTION_DB_BAKE_RND=
NOTION_DB_BOB_BRAND=
NOTION_DB_AIR_RESEARCH=
NOTION_DB_DRAFT_BLOCKS=
NOTION_DB_BUILD=

############################################
# Vertex AI (GCP)
############################################

GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001
AUTH_MODE=adc
GOOGLE_APPLICATION_CREDENTIALS=C:/keys/vertex-service-account.json

############################################
# Gemini AI Studio (alternative to Vertex)
############################################

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

############################################
# reCAPTCHA v3
############################################

RECAPTCHA_SECRET_KEY=

############################################
# Google Drive
############################################

GOOGLE_SHARED_DRIVE_ID=
CANON_ROOT_NAME=INFINITE_NETWORK_CANON
