############################################
# TEAM AI — IEHQ Notion MCP — Canon Env v1.0
# Extend-only. No double-canon.
############################################

# Server
PORT=3002

############################################
# Notion Auth (REQUIRED)
############################################

# Canon input expected by code:
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional legacy inputs (only use if you want; code will map them if NOTION_API_KEY is missing)
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: pin API version if your server supports it
NOTION_VERSION=2022-06-28

############################################
# Core OS Canon DBs
############################################

NOTION_DB_MISSIONS=c8ff256e912b40e1953801820145ec70
NOTION_DB_BUILD=1f1ffa1fcd2a41b7b5dda40004d742ef
NOTION_DB_DRAFT_BLOCKS=fc7d6457e2df48cdab96b33bfdcfeae6
NOTION_DB_ARK_ASSETS=5bb039e29feb4471a1e532b6871a15af
NOTION_DB_TIMELINE=88aca27db46a469a8c8acf820dbf8352
NOTION_DB_LAW_DOCS=49a269d4f214460189447e5001d29912
NOTION_DB_CLASS_KB=2e71322484694e279df01ac710865ab0
NOTION_DB_BAKE_RND=57193e9e23d74f18a43377e4f748abb7
NOTION_DB_BOB_BRAND=01576bd9a67646198dbafe8687628914
NOTION_DB_AIR_RESEARCH=ae9df0427c124aa19652dd6e90e0a7f3
NOTION_DB_AGENTS=dddf83e493ff47318a15b0c999c03d9f
NOTION_DB_INBOX=83e5337843da4b0cbcb4bda4f4e75645

############################################
# v1.0 Canon Adds (REQUIRED)
############################################

# TASKS is the approved shared write surface for task rows.
# BUILD fallback remains disabled while TASKS remediation stays bounded.
NOTION_DB_TASKS=de4cbae982904c0a93c9d0b896ebe178

# MISSION_RUNS is the active live write surface.
# AAR content is written back to the same Mission Runs row.
# Mission resolution depends on the persisted Mission relation, not SYNC_KEY.
NOTION_DB_RUNS_AARS=

############################################
# Registries (CANON)
############################################

NOTION_DB_ENTITIES=14ce1b7c5cd949b69dbc10f740c3bb38
NOTION_DB_ROOMS=5dabf365bb444f14aa04c8ed5eab691a
NOTION_DB_ARK_REGISTRY=9702345348bb401b82e52484a8f6df7d

############################################
# Legacy DB key aliases (ONLY if older callers still reference these keys)
# NOTE: do NOT use ${VAR} expansion; repeat the values.
############################################

# Compatibility alias only. Keep this aligned to NOTION_DB_TASKS if older callers still require it.
NOTION_TASKS_DB_ID=de4cbae982904c0a93c9d0b896ebe178

# Canonical aliases may point to the same live Mission Runs surface.
# They do not provide a Mission lookup fallback.
NOTION_MISSION_RUNS_DB_ID=
NOTION_AAR_DB_ID=
