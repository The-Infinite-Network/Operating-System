# ─────────────────────────────────────────────────────────────
# mcp-todo  — Microsoft To Do via Graph API  (INOS_E0)
# ─────────────────────────────────────────────────────────────

# Access token for Microsoft Graph API (Tasks.ReadWrite scope)
# Get one from: https://developer.microsoft.com/en-us/graph/graph-explorer
#   1. Sign in with your Microsoft account
#   2. Make sure "Tasks.ReadWrite" is in your permissions
#   3. Run any query, then copy the access token from the request headers
#
# Note: tokens expire in ~1 hour. For persistent use, set up an app registration
# with MICROSOFT_CLIENT_ID / MICROSOFT_CLIENT_SECRET (enterprise tenant only).
MS_TODO_ACCESS_TOKEN=your_access_token_here

# ── Optional: App registration (client credentials) ──────────
# Only works for enterprise (Azure AD) tenants with Tasks.ReadWrite.All app permission.
# For personal Microsoft accounts, use MS_TODO_ACCESS_TOKEN above.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Server ───────────────────────────────────────────────────
PORT=3004
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5173
