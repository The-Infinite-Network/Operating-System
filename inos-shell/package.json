{
    "name": "inos-shell",
    "version": "0.1.0",
    "description": "INOS Shell - Command Center for TEAM AI (INOS_E0 project)",
    "private": true,
    "keywords": [
        "inos",
        "shell",
        "command-center",
        "team-ai"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "server": "ts-node server/index.ts",
        "server:dev": "nodemon --watch 'server/**/*.ts' --exec ts-node server/index.ts",
        "dev:all": "concurrently \"npm run dev\" \"npm run server:dev\"",
        "lint:canon": "node ./scripts/check-canonical-api.mjs",
        "lint": "npm run lint:canon && tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "axios": "^1.7.2",
        "cors": "^2.8.5",
        "date-fns": "^3.6.0",
        "dexie": "^4.0.7",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "firebase": "^10.12.0",
        "lucide-react": "^0.562.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-google-recaptcha-v3": "^1.11.0",
        "react-router-dom": "^6.30.3",
        "uuid": "^9.0.1",
        "zustand": "^4.5.4"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.12.7",
        "@types/react": "^18.2.46",
        "@types/react-dom": "^18.2.18",
        "@types/uuid": "^9.0.8",
        "@vitejs/plugin-react": "^4.3.1",
        "autoprefixer": "^10.4.19",
        "concurrently": "^8.2.2",
        "nodemon": "^3.1.0",
        "postcss": "^8.4.38",
        "tailwindcss": "^3.4.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vite": "^7.3.0",
        "vitest": "^4.0.15"
    }
}
