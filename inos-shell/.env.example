# INOS Shell Client Environment Configuration
VITE_INOS_API_ENDPOINT=http://localhost:3001
VITE_NOTION_DB_MISSIONS=

# Scoped Identity (For Business Context Switching)
VITE_GCP_PROJECT_ID=infinite-earth-mcp
